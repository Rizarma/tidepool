# ─── Tidepool Environment Variables ─────────────────────────────────────────

# Production site URL — used for OpenGraph metadata and canonical URLs.
# Set this to your deployed domain (e.g. https://tidepool.rizarma.com).
NEXT_PUBLIC_SITE_URL=https://tidepool.rizarma.com

# Birdeye API key — required for Moving Average indicators on pool scans.
# Sign up free at https://birdeye.so to get a key.
# Without this, pool scans still work but indicators are omitted.
BIRDEYE_API_KEY=

# Solana RPC — used for on-chain mint account lookups.
# The app round-robins across multiple endpoints for resilience:
#   1. SOLANA_RPC_URL (primary)
#   2. NEXT_PUBLIC_SOLANA_RPC_URL (backward compatible)
#   3. SOLANA_RPC_URLS (comma-separated fallback list)
#   4. https://api.mainnet-beta.solana.com (default public)
# Set private RPCs (e.g. Helius, QuickNode) for better reliability.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=
# Comma-separated list of additional Solana RPC endpoints for rotation.
# Example: SOLANA_RPC_URLS=https://rpc.helius.xyz/?api-key=xxx,https://solana-mainnet.g.alchemy.com/v2/xxx
SOLANA_RPC_URLS=

# Upstash Redis — optional but strongly recommended for production.
# Provides shared caching across all serverless instances so that
# one cached token scan in Tokyo is instantly available in New York.
# Without this, the app falls back to an in-memory Map (per-instance only).
# Sign up free at https://upstash.com (10,000 requests/day on free tier).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
