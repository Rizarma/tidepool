# ─── Tidepool Environment Variables ─────────────────────────────────────────

# Birdeye API key — required for Moving Average indicators on pool scans.
# Sign up free at https://birdeye.so to get a key.
# Without this, pool scans still work but indicators are omitted.
BIRDEYE_API_KEY=

# Solana RPC URL — used for on-chain mint account lookups.
# The app tries NEXT_PUBLIC_SOLANA_RPC_URL first, then SOLANA_RPC_URL,
# then falls back to the public https://api.mainnet-beta.solana.com endpoint.
# Set a private RPC (e.g. Helius, QuickNode) for better reliability.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=
