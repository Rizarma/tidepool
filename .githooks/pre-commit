#!/usr/bin/env bash
set -euo pipefail

if ! command -v trufflehog >/dev/null 2>&1; then
  echo "⚠️  trufflehog not installed; skipping secret scan."
  echo "   Install with: brew install trufflehog"
  echo "   Or visit: https://github.com/trufflesecurity/trufflehog#installation"
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | tr '\n' ' ')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "🔐 Running TruffleHog on staged files..."

trufflehog filesystem $STAGED_FILES \
  --only-verified \
  --fail \
  --exclude-paths=.trufflehog-exclude

echo "✅ No verified secrets found."
